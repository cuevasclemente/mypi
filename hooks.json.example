{
  "hooks": [
    {
      "name": "session-end-checklist",
      "trigger": "session_start",
      "message": "End-of-session checklist — this is injected at session start, but the items are meant to be done at THE END, after the user's final request is fully handled and just before you would otherwise stop responding. Do NOT act on these now. Remember them, then work through them at session end:\n\n- [ ] Journal the results of this session if something significant happened\n  - [ ] *If this session resulted in the creation or modification of pi extensions/features, don't forget to install them to the user's pi context (~/.pi/agent/extensions, /agents, /teams)*"
    }
  ]
}
